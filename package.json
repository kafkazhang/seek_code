{
  "name": "seekcode",
  "version": "0.4.2",
  "description": "纯本地 AI 编程桌面工具 · 由 DeepSeek 驱动 · 仅需一个 API Key",
  "author": "SeekCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kafkazhang/seek_code.git"
  },
  "homepage": "https://github.com/kafkazhang/seek_code#readme",
  "bugs": {
    "url": "https://github.com/kafkazhang/seek_code/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:mac-x64": "electron-vite build && electron-builder --mac --x64",
    "package:mac-arm64": "electron-vite build && electron-builder --mac --arm64",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.10.0",
    "marked": "^12.0.2",
    "monaco-editor": "^0.52.2",
    "openai": "^4.67.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/chakra-petch": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@fontsource/sora": "^5.1.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "zustand": "^5.0.14"
  }
}
