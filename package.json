{
  "name": "seekcode",
  "version": "0.4.2",
  "description": "纯本地 AI 编程桌面工具 · 由 DeepSeek 驱动 · 仅需一个 API Key",
  "author": "SeekCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kafkazhang/seek_code.git"
  },
  "homepage": "https://github.com/kafkazhang/seek_code#readme",
  "bugs": {
    "url": "https://github.com/kafkazhang/seek_code/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:mac-x64": "electron-vite build && electron-builder --mac --x64",
    "package:mac-arm64": "electron-vite build && electron-builder --mac --arm64",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "openai": "^6.44.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@fontsource/chakra-petch": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@fontsource/sora": "^5.1.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.3.4",
    "vitest": "^2.0.5",
    "zustand": "^4.5.4"
  }
}
